# GEMINI_API_KEY: Required only if you incorporate Gemini AI API features.
GEMINI_API_KEY=""

# APP_URL: Injected automatically by some builder platforms.
APP_URL=""

# Demo mode is opt-in. Keep false in production.
VITE_DEMO_MODE="false"
DEMO_MODE="false"

# Supabase configuration.
# VITE_* values are used by the React client. SUPABASE_SERVICE_ROLE_KEY is server-only.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Public contact shown in the footer. Leave blank to hide the public email link.
VITE_PUBLIC_CONTACT_EMAIL=""

# Cloudinary unsigned upload configuration for project screenshots.
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET=""

# Resend email notification configuration.
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
OWNER_EMAIL=""
